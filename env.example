## Supabase Realtime (signaling + chat)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLIC_KEY=your-public-key

## Signaling token (JWT signing)
# Shared secret used for signaling token JWT between Next.js and clients
SIGNALING_JWT_SECRET=your-secret-key

## MongoDB Atlas (support chat + persistence)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/yourdb?retryWrites=true&w=majority
# Optional: override DB name (otherwise taken from URI)
# MONGODB_DB=yourdb

# Korean quiz pool (korean-quiz project DB on same cluster)
KOREAN_QUIZ_DB=korean_quiz

## Auth (Magic Link via Resend)
AUTH_JWT_SECRET=your-long-random-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL="Kaja <no-reply@your-domain.com>"
# Welcome PDF (public R2) sent right after newsletter subscribe
# Upload: npm run newsletter:upload-pdf  (source: book-preview-sample.pdf)
# NEWSLETTER_WELCOME_PDF_URL=https://file.kajakorean.com/downloads/kaja-korean-book-preview.pdf
# NEWSLETTER_PDF_R2_KEY=downloads/kaja-korean-book-preview.pdf
# Welcome email book cover image (defaults to NEXT_PUBLIC_SITE_URL/book-samples/book-cover.png)
# NEWSLETTER_WELCOME_BOOK_COVER_URL=https://kajakorean.com/book-samples/book-cover.png
# Optional: HMAC secret for newsletter unsubscribe links (defaults to AUTH_JWT_SECRET)
# NEWSLETTER_UNSUBSCRIBE_SECRET=your-long-random-secret
# Weekly quiz example sentences — Azure chat deployment (defaults to AZURE_OPENAI_DEPLOYMENT)
# NEWSLETTER_QUIZ_EXAMPLE_CHAT_DEPLOYMENT=gpt-4.1
# Weekly quiz email images (flattened JPEG on R2; defaults to R2_PUBLIC_BASE_URL / file.kajakorean.com)
# NEWSLETTER_QUIZ_IMAGE_PUBLIC_BASE_URL=https://file.kajakorean.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

## Meeting provider (Kaja Meet vs Google Meet)
# kaja_meet: built-in WebRTC (Kaja Meet)
# google_meet: create a Google Calendar event + Meet link on booking
MEETING_PROVIDER=kaja_meet

## Google Calendar (Google Meet link generation)
# Uses a single organizer Google account with OAuth2 refresh_token.
GOOGLE_CALENDAR_CLIENT_ID=your-calendar-oauth-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=your-calendar-oauth-client-secret
GOOGLE_CALENDAR_REFRESH_TOKEN=your-refresh-token
# Calendar ID (usually "primary" for the organizer account)
GOOGLE_CALENDAR_ID=primary

## Admin / Cron
# Used to protect admin-only endpoints (e.g. reminder cron runner)
ADMIN_API_KEY=your-admin-api-key
# Comma-separated email recipients for admin reminders (e.g. you + assistants)
REMINDER_ADMIN_EMAILS=minjae@example.com

## Teacher authentication
STREAM_TEACHER_KEY=your-teacher-key

## ICE servers (STUN-first, TURN fallback)
# Optional: Custom STUN servers JSON array (defaults to Google STUN)
# STUN_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]

# TURN fallback (Twilio Network Traversal Service)
# Server-side only (do NOT prefix with NEXT_PUBLIC_)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: TTL seconds for ephemeral TURN creds (default 600)
# TWILIO_TURN_TTL_SECONDS=600

# Korean quiz pool (korean-quiz project DB on same cluster)
KOREAN_QUIZ_DB=korean_quiz
# Optional: korean-quiz admin URL for flagged-quiz review page links
# NEXT_PUBLIC_KOREAN_QUIZ_ADMIN_URL=http://localhost:3000/admin/korean-quiz

# Korean Quiz mobile app — store listing URLs (home + vocab quiz)
# NEXT_PUBLIC_KOREAN_QUIZ_APP_STORE_URL=https://apps.apple.com/app/6784340207
# NEXT_PUBLIC_KOREAN_QUIZ_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.neoproject.korean_quiz_app

# Korean Quiz R2 public CDN (same origin as quiz imageUrl — e.g. pub-….r2.dev)
# KOREAN_QUIZ_R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev

## Deprecated (old WebSocket signaling server - no longer used)
# SIGNALING_WS_URL=ws://localhost:8787/ws
