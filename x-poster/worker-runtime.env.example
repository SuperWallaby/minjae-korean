# Copy to worker-runtime.env on lab-worker (never commit secrets).

# MongoDB (same as korean-teacher-mj .env.local)
MONGODB_URI=mongodb+srv://...
MONGODB_DB=yourdb

NEXT_PUBLIC_SITE_URL=https://kajakorean.com

# X API — OAuth 2.0 (preferred; refresh before each post)
X_OAUTH2_CLIENT_ID=your_client_id
X_OAUTH2_CLIENT_SECRET=your_client_secret
X_OAUTH2_ACCESS_TOKEN=your_oauth2_access_token
X_OAUTH2_REFRESH_TOKEN=your_oauth2_refresh_token

# X API — OAuth 1.0a fallback
# X_API_KEY=your_consumer_key
# X_API_SECRET=your_consumer_secret
# X_ACCESS_TOKEN=your_access_token
# X_ACCESS_TOKEN_SECRET=your_access_token_secret

# Optional: prettier tweet URLs (https://x.com/{user}/status/...)
X_USERNAME=your_x_handle

# Local capybara render on worker
CAPYBARA_RENDER_SERVICE_URL=http://127.0.0.1:8766
